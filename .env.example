# Copy to .env and adjust. NEVER commit real secrets — .env is gitignored.

MT_ENVIRONMENT=dev
MT_LOG_LEVEL=INFO
MT_JSON_LOGS=false

# Storage (matches docker-compose.yml)
MT_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# Set to run integration tests against a real Postgres:
# MT_TEST_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# --- Execution safety -------------------------------------------------------
# Defaults are the safe state. Arming live trading intentionally requires BOTH
# switches; the execution tier (Phase 5) calls Settings.assert_live_allowed().
MT_EXECUTION_MODE=paper
MT_LIVE_TRADING_ENABLED=false
MT_MAX_GROSS_EXPOSURE=1.0
MT_MAX_POSITION_WEIGHT=0.10
MT_MAX_DRAWDOWN_HALT=0.20
