# Copy to .env and adjust. NEVER commit real secrets — .env is gitignored.

MT_ENVIRONMENT=dev
MT_LOG_LEVEL=INFO
MT_JSON_LOGS=false

# Storage. NOTE: this localhost URL is for running the engine OUTSIDE Docker.
# The docker-compose stack overrides MT_DATABASE_URL to the in-network host `db`.
MT_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# Set to run integration tests against a real Postgres:
# MT_TEST_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# --- Execution & trading safety (PAPER-FIRST) -------------------------------
# Defaults are the safe state. Live trading is a separate, human-approved,
# gated decision (Phase 9); the system must never enable it on its own. Arming
# live intentionally requires BOTH switches below AND passing the paper->live
# graduation gates (see DECISIONS.md D10).
MT_EXECUTION_MODE=paper
MT_LIVE_TRADING_ENABLED=false
MT_LIVE_DRY_RUN=true
# Guardrail caps (enforced by the risk/execution tiers in Phase 8):
MT_MAX_GROSS_EXPOSURE=1.0
MT_MAX_NET_EXPOSURE=1.0
MT_MAX_POSITION_WEIGHT=0.10
# Catastrophic kill switch: halt for good once drawdown from the peak crosses this.
MT_MAX_DRAWDOWN_HALT=0.20
# Daily-loss kill: halt (human re-arm) once equity falls this far below the prior
# close. NOW ENFORCED (was inert). 0 = off. For an aggressive book, ~0.08.
MT_MAX_DAILY_LOSS=0.0
MT_MAX_ORDERS_PER_INTERVAL=50
# Hard cap on deployable capital. Default $1,000 keeps paper sizing tiny; raise it
# (e.g. 25000) for a more meaningful paper simulation. Live is still gated.
MT_CAPITAL_CEILING=1000.0
# Universe to scan each cycle: "liquid" (broad, ~110 names across all sectors;
# default), "watchlist" (the 8 megacaps), or a comma-separated custom list.
# MT_MAX_POSITIONS caps the book so breadth becomes a diversified portfolio
# instead of 2-3 megacaps. Set 0 to remove the cap (hold everything selected).
# (A broad universe is heavier for the per-minute intraday loop.)
MT_UNIVERSE=liquid
MT_MAX_POSITIONS=20
# Ranking model: "composite" (transparent equal-weight; default) or "forecast"
# (trained calibrated ensemble, daily cycle only). Keep "composite" until the
# forecaster beats the baseline out-of-sample: `market-trader validate-forecaster`.
MT_SCORER=composite
# Learning loop: weight the composite's signals by their measured IC (from graded
# past predictions) instead of equal weights, dropping signals whose |IC| decays
# below MT_IC_MIN_ABS. Sign-aware and self-pruning; falls back to equal weights
# until there's graded data, so it's a no-op on a cold start. Composite only.
MT_IC_WEIGHTING=true
MT_IC_MIN_ABS=0.02
# Holding discipline + sizing. MT_EXIT_BAND_MULTIPLE keeps a held name until it
# falls out of the top (entry_count x multiple) — higher = holds longer, trades
# less (2.0 = hold until it leaves ~2x the entry band). MT_RISK_WEIGHTING:
# "inverse_vol" sizes each name to ~equal risk; "equal" splits evenly;
# "conviction" bets more on the strongest signals (aggressive offense).
MT_EXIT_BAND_MULTIPLE=2.0
MT_RISK_WEIGHTING=inverse_vol
# Per-name hard stop: flatten a holding once it's this far below its entry price,
# regardless of signal — the "cut your losers" rail. 0 = off, 0.15 = cut at -15%.
MT_STOP_LOSS_PCT=0.0
# News signal (daily cycle only; OFF by default). When true, each daily cycle
# pulls recent GDELT news for the universe (free, no key) and adds news-flow +
# sentiment features to the ranking. Heavy (per-symbol fetch), so it's daily, not
# intraday. Validate it helps before relying on it (score-predictions shows its IC).
MT_NEWS_ENABLED=false
MT_NEWS_WINDOW_DAYS=7
MT_NEWS_TIMESPAN=3d

# --- Broker (Alpaca; paper-first) -------------------------------------------
# Paper keys from https://app.alpaca.markets/ -> Home -> "Paper" -> API Keys.
# Keys live ONLY in the env / secret manager — never in code or git. MT_ALPACA_PAPER
# stays true until live is earned (live also needs the two execution switches above).
# MT_ALPACA_KEY_ID=<YOUR_ALPACA_PAPER_KEY_ID>
# MT_ALPACA_SECRET_KEY=<YOUR_ALPACA_PAPER_SECRET_KEY>
MT_ALPACA_PAPER=true
# Market-data feed: "iex" is free; the paid consolidated "sip" feed 403s on free
# plans. Switch to sip once you subscribe.
MT_ALPACA_DATA_FEED=iex

# --- Intraday live loop (continuous, market-reactive; PAPER; OFF by default) -
# When enabled AND the market is open, `serve` runs a minute-bar trading cycle
# every MT_INTRADAY_INTERVAL_SECONDS, reacting to live price action — staying
# fully paper-gated. Flip it on only after `cycle --intraday` behaves as you want.
# The lookbacks count MINUTES (signals are computed on minute bars).
MT_INTRADAY_ENABLED=false
MT_INTRADAY_TIMEFRAME=1Min
# How often the loop wakes (seconds). 300 = 5 min: enough headroom for a broad
# universe; lower it only with a narrow universe.
MT_INTRADAY_INTERVAL_SECONDS=300
MT_INTRADAY_LOOKBACK_MINUTES=180
MT_INTRADAY_TOP_QUANTILE=0.3
MT_INTRADAY_MOMENTUM_LOOKBACK=30
MT_INTRADAY_MEANREV_LOOKBACK=10
MT_INTRADAY_VOL_WINDOW=30

# --- Daily scheduler (hands-off; PAPER; OFF by default) ---------------------
# When enabled, `serve` runs the end-of-day cycle automatically once per TRADING
# day, triggered by the market close (weekends/holidays skip themselves). This is
# the recommended hands-off path: it feeds the learning loop (each session logs
# predictions that grade themselves later). Prefer this over the intraday loop.
MT_DAILY_CYCLE_ENABLED=false
MT_DAILY_CYCLE_POLL_SECONDS=300

# --- Reasoning / LLM (hosted Anthropic API; Claude Code is dev-time only) ----
# Production calls the hosted Anthropic API (no local LLM on the VPS). Get a key
# at https://console.anthropic.com/ . Managed, rotatable secret — never commit it.
# MT_ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
MT_ANTHROPIC_MODEL=claude-sonnet-4-6
MT_LLM_DAILY_CALL_BUDGET=200

# --- AGGRESSIVE PRESET (paper) — offense + trader-grade rails ---------------
# Uncomment to chase higher returns WITH defined risk. Offense: concentrate and
# bet by conviction. Defense: cut losers (-15%), kill the day at -8%, kill the
# book for good at -30%. Leverage stays OFF here — earn it after the edge proves
# out with real, unlevered fills (raise MT_MAX_GROSS_EXPOSURE last).
# MT_MAX_POSITIONS=10
# MT_RISK_WEIGHTING=conviction
# MT_MAX_POSITION_WEIGHT=0.25
# MT_STOP_LOSS_PCT=0.15
# MT_MAX_DAILY_LOSS=0.08
# MT_MAX_DRAWDOWN_HALT=0.30
# MT_MAX_GROSS_EXPOSURE=1.0   # 1.5-2.0 = leverage; only once the edge is proven

# --- Off-box backups (DigitalOcean Spaces / S3-compatible) -----------------
# Used by scripts/backup_db.sh to ship pg_dump off the Droplet. Keys are managed
# secrets — never commit them. Create a Space + access keys in the DO console.
# SPACES_BUCKET=your-space-name
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_ACCESS_KEY_ID=<YOUR_SPACES_KEY>
# AWS_SECRET_ACCESS_KEY=<YOUR_SPACES_SECRET>

# --- DigitalOcean management API (optional ops automation) ------------------
# Powers monitoring-alert policies, pre-migration snapshots, and Cloud Firewall
# management. A powerful token (can change infra) — env/secret-manager only.
# Create at: DigitalOcean console -> API -> Tokens (scoped write).
# DO_API_TOKEN=<YOUR_DIGITALOCEAN_API_TOKEN>
