# Copy to .env and adjust. NEVER commit real secrets — .env is gitignored.

MT_ENVIRONMENT=dev
MT_LOG_LEVEL=INFO
MT_JSON_LOGS=false

# Storage (matches docker-compose.yml)
MT_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# Set to run integration tests against a real Postgres:
# MT_TEST_DATABASE_URL=postgresql+psycopg://market:market@localhost:5432/market_trader

# --- Execution & trading safety (PAPER-FIRST) -------------------------------
# Defaults are the safe state. Live trading is a separate, human-approved,
# gated decision (Phase 9); the system must never enable it on its own. Arming
# live intentionally requires BOTH switches below AND passing the paper->live
# graduation gates (see DECISIONS.md D10).
MT_EXECUTION_MODE=paper
MT_LIVE_TRADING_ENABLED=false
MT_LIVE_DRY_RUN=true
# Guardrail caps (enforced by the risk/execution tiers in Phase 8):
MT_MAX_GROSS_EXPOSURE=1.0
MT_MAX_NET_EXPOSURE=1.0
MT_MAX_POSITION_WEIGHT=0.10
MT_MAX_DRAWDOWN_HALT=0.20
MT_MAX_DAILY_LOSS=0.02
MT_MAX_ORDERS_PER_INTERVAL=50
MT_CAPITAL_CEILING=1000.0
# Alpaca keys live ONLY in the secret manager / env — never in code or git.
# Separate paper and live key sets; live keys added only when live is earned:
# MT_ALPACA_PAPER_KEY_ID=...
# MT_ALPACA_PAPER_SECRET=...

# --- Reasoning / LLM (hosted Anthropic API; Claude Code is dev-time only) ----
# Production calls the hosted Anthropic API (no local LLM on the VPS). Get a key
# at https://console.anthropic.com/ . Managed, rotatable secret — never commit it.
# MT_ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
MT_ANTHROPIC_MODEL=claude-sonnet-4-6
MT_LLM_DAILY_CALL_BUDGET=200

# --- Off-box backups (DigitalOcean Spaces / S3-compatible) -----------------
# Used by scripts/backup_db.sh to ship pg_dump off the Droplet. Keys are managed
# secrets — never commit them. Create a Space + access keys in the DO console.
# SPACES_BUCKET=your-space-name
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_ACCESS_KEY_ID=<YOUR_SPACES_KEY>
# AWS_SECRET_ACCESS_KEY=<YOUR_SPACES_SECRET>
